# ============ Server ============
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,https://www.macalinhub.com
API_BASE_URL=https://www.macalinhub.com
FRONTEND_URL=https://macalinhub.com

# ============ Database ============
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=barofinder
DB_CONNECTION_LIMIT=10

# ============ Authentication ============
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
TOKEN_HASH_SECRET=
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800
BCRYPT_SALT_ROUNDS=10
EMAIL_VERIFICATION_REQUIRED=false
ALLOW_LEGACY_PLAINTEXT_PASSWORDS=false

# ============ File Storage ============
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ============ Email (Optional) ============
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ============ Rate Limiting ============
TRUST_PROXY=1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=25
UPLOAD_RATE_LIMIT_MAX=30
